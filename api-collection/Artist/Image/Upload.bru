meta {
  name: Upload
  type: http
  seq: 1
}

post {
  url: {{BASE_URL}}/v1/artists/:id/images
  body: multipartForm
  auth: inherit
}

params:path {
  id: 1
}

body:multipart-form {
  image: @file(/home/alex/Downloads/20230912_nirvanajubilaeum_2_52c5ec1e-4a78-4f5a-b5f3-3b054e9cc10c.jpg)
}

settings {
  encodeUrl: true
  timeout: 0
}
